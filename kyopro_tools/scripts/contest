#!/bin/bash

# 新しいコンテストに向けて手元のファイルを整理する。
#   残す : 補助スクリプト・設定、kp 関連 (kp, online-judge-tools.md)、
#          code / z で始まるファイル (code.cpp, z.cpp, zz.cpp, z01.cpp など)
#   消す : それ以外の解答ファイル・生成物、./samples/ 以下

HERE=$(pwd)

# 削除しないもの（インフラ・設定・補助スクリプト・kp 関連）
EXCLUDE=(
    ".devcontainer"
    ".vscode"
    "kyopro_library"
    "atcoder"
    "esc"
    "random_test"
    "contest"
    "cmp"
    "copy"
    "test"
    "rand"
    "check"
    "compress"
    "makefile"
    "Dockerfile"
    "compile_flags.txt"
    "file"
    "kp"
    "online-judge-tools.md"
)

# kp が取得したサンプルを削除（ディレクトリごと。kp -d で再生成される）
rm -rf "$HERE/samples"

# esc/ の解答アーカイブを削除（code / z で始まるファイルは残す）
for f in "$HERE"/esc/*.cpp; do
    [[ -e "$f" ]] || continue
    case "$(basename "$f")" in
        code*|z*) ;;          # 残す（code / z で始まるファイル）
        *)        rm -f "$f" ;;
    esac
done

# ルート直下を整理：EXCLUDE にも code* / z* にも該当しないものを削除
for file in $(ls "$HERE"); do
    case "$file" in
        code*|z*) continue ;; # code / z で始まるファイルは残す
    esac
    if [[ ! " ${EXCLUDE[@]} " =~ " ${file} " ]]; then
        rm -rf "$HERE/$file"
    fi
done

clear
